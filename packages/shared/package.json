{
  "name": "@multi-table/shared",
  "version": "0.0.1",
  "type": "module",
  "description": "Shared utilities and types for multi-table",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch"
  },
  "devDependencies": {
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "table",
    "utilities"
  ],
  "license": "MIT"
}
